# Poligiros environment variables.
#
# Architecture: frontend on Cloudflare Pages, backend dockerized on your machine
# (later a server), exposed via a Cloudflare Tunnel. There are three .env files:
#
#   .env            ← ROOT: read by `docker compose -f docker-compose.local.yml`
#   backend/.env    ← host-side prisma commands (seed / migrate / studio)
#   frontend/.env   ← only if you run the frontend locally with `vite dev`
#
# (The Cloudflare Pages frontend gets its VITE_API_URL from the Pages dashboard,
#  not from a file.)

# ═════════════════════════════════════════════════════════════════════════════
# ROOT  (.env)  — drives the dockerized stack
# ═════════════════════════════════════════════════════════════════════════════

# Postgres (the docker container)
POSTGRES_USER=poligiros
POSTGRES_PASSWORD=change-me                          # pick any dev password
POSTGRES_DB=poligiros

# Backend
JWT_SECRET=generate-with-openssl-rand-base64-32      # openssl rand -base64 32
FRONTEND_URL=https://app.poligiros.com               # your Cloudflare Pages origin (CORS allow-list)

# Cloudflare Tunnel — token from Zero Trust ▸ Networks ▸ Tunnels ▸ (your tunnel)
CLOUDFLARE_TUNNEL_TOKEN=

# Seed credentials (used when you run `npm run db:seed`)
SUPERVISOR_EMAIL=gaby@poligiros.com
SUPERVISOR_PASSWORD=change-me

# Optional — features fail gracefully if blank
OPENAI_API_KEY=                                      # Anclas AI insight
RESEND_API_KEY=                                      # notification emails
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=poligiros
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.r2.dev

# ═════════════════════════════════════════════════════════════════════════════
# backend/.env  — for host-side prisma commands against the dockerized DB
# (host sees Postgres on localhost:5432; the container sees it as `postgres`)
# ═════════════════════════════════════════════════════════════════════════════

# DATABASE_URL=postgresql://poligiros:change-me@localhost:5432/poligiros
# JWT_SECRET=...            # same value as ROOT
# SUPERVISOR_EMAIL=gaby@poligiros.com
# SUPERVISOR_PASSWORD=change-me

# ═════════════════════════════════════════════════════════════════════════════
# frontend/.env  — ONLY for local `npm run dev` (the Pages build uses the dashboard)
# ═════════════════════════════════════════════════════════════════════════════

# VITE_API_URL=http://localhost:3001
