# Poligiros environment variables.
# This repo is split into two apps. Copy the relevant section into a local .env:
#   backend/.env   ← the BACKEND section
#   frontend/.env  ← the FRONTEND section

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND  (backend/.env)
# ─────────────────────────────────────────────────────────────────────────────

# Required
DATABASE_URL=postgresql://user:password@localhost:5432/poligiros
JWT_SECRET=generate-with-openssl-rand-base64-32     # openssl rand -base64 32

# CORS / server
FRONTEND_URL=http://localhost:5173                  # allowed origin
PORT=3001                                           # API port (default 3001)

# Seed credentials (used by `npm run db:seed`)
SUPERVISOR_EMAIL=gaby@poligiros.com
SUPERVISOR_PASSWORD=your-supervisor-password

# Optional — features fail gracefully if blank in development
OPENAI_API_KEY=                                     # Anclas AI insight
RESEND_API_KEY=                                     # notification emails
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=poligiros
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.r2.dev

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND  (frontend/.env)
# ─────────────────────────────────────────────────────────────────────────────

VITE_API_URL=http://localhost:3001
