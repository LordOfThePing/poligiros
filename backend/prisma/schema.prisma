generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERVISOR
  STUDENT_COACH
}

enum TestType {
  ANCLAS_CARRERA
  TABLERO_IDEAS
  PLAN_VITAL
  PIRAMIDE_PROPOSITO
}

enum SupervisionStatus {
  PENDING
  REVIEWED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(STUDENT_COACH)
  createdAt DateTime @default(now())

  clients             Client[]
  enrollments         Enrollment[]
  moduleProgress      ModuleProgress[]
  supervisionRequests SupervisionRequest[] @relation("StudentRequests")
  supervisionReviews  SupervisionRequest[] @relation("SupervisorReviews")
  sessionRecords      SessionRecord[]
}

model Cohort {
  id          String       @id @default(cuid())
  name        String
  startDate   DateTime
  active      Boolean      @default(true)
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  cohortId   String
  user       User     @relation(fields: [userId], references: [id])
  cohort     Cohort   @relation(fields: [cohortId], references: [id])
  enrolledAt DateTime @default(now())

  @@unique([userId, cohortId])
}

model Module {
  id          String           @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  orderIndex  Int
  published   Boolean          @default(false)
  materials   Material[]
  progress    ModuleProgress[]
  createdAt   DateTime         @default(now())
}

model Material {
  id       String @id @default(cuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title    String
  fileUrl  String
  fileType String
}

model ModuleProgress {
  id          String   @id @default(cuid())
  userId      String
  moduleId    String
  user        User     @relation(fields: [userId], references: [id])
  module      Module   @relation(fields: [moduleId], references: [id])
  completedAt DateTime @default(now())

  @@unique([userId, moduleId])
}

model Client {
  id          String           @id @default(cuid())
  studentId   String
  student     User             @relation(fields: [studentId], references: [id])
  name        String
  email       String
  assignments TestAssignment[]
  sessions    SessionRecord[]
  createdAt   DateTime         @default(now())
}

model Test {
  id          String           @id @default(cuid())
  type        TestType         @unique
  title       String
  description String
  orderIndex  Int
  assignments TestAssignment[]
}

model TestAssignment {
  id          String    @id @default(cuid())
  testId      String
  test        Test      @relation(fields: [testId], references: [id])
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  assignedBy  String
  assignedAt  DateTime  @default(now())
  completedAt DateTime?

  // A1 magic-link fields
  accessToken          String?   @unique
  completeBy           DateTime?
  resultsViewableUntil DateTime?

  response    TestResponse?
  supervision SupervisionRequest?

  @@unique([testId, clientId])
}

model TestResponse {
  id           String         @id @default(cuid())
  assignmentId String         @unique
  assignment   TestAssignment @relation(fields: [assignmentId], references: [id])
  responses    Json
  submittedAt  DateTime       @default(now())
}

model SupervisionRequest {
  id              String            @id @default(cuid())
  assignmentId    String            @unique
  assignment      TestAssignment    @relation(fields: [assignmentId], references: [id])
  studentId       String
  student         User              @relation("StudentRequests", fields: [studentId], references: [id])
  studentNotes    String?
  supervisorId    String?
  supervisor      User?             @relation("SupervisorReviews", fields: [supervisorId], references: [id])
  supervisorNotes String?
  coachFeedback   String?
  status          SupervisionStatus @default(PENDING)
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
}

model SessionRecord {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id])
  clientId  String
  client    Client @relation(fields: [clientId], references: [id])
  sessionNum Int

  coacheeName     String
  coacheeAge      String
  coacheeSex      String
  coacheeWorks    Boolean
  coacheePosition String?
  sessionDate     DateTime
  mainOutputs     String
  toolsAndResults String
  conclusions     String

  createdAt DateTime @default(now())
}
